<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%-5level -> %msg%n"/>
        </Console>
        
        <!-- File Appender -->
        <File name="File" fileName="logs/application.log" append="false">
            <PatternLayout pattern="%-5level -> %msg%n"/>
        </File>

        <!-- Server File Appender -->
        <File name="SpecificClassFile" fileName="logs/server.log" append="false">
            <PatternLayout pattern="%-5level -> %msg%n"/>
        </File>
    </Appenders>
    
    <Loggers>
        <!-- Specific Logger for a class -->
        <Logger name="pl.edu.pg.networking.Server" level="debug" additivity="false">
            <AppenderRef ref="SpecificClassFile"/>
            <AppenderRef ref="Console"/>
        </Logger>

        
        <!-- Specific Logger for a package
        <Logger name="com.yourpackage.subpackage" level="trace">
            <AppenderRef ref="File"/>
        </Logger>  -->
        
        <!-- Root Logger -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>
</Configuration>